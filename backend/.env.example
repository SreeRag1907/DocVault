# Server
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# Database - RDS endpoint in production, local Postgres for dev
PGHOST=localhost
PGPORT=5432
PGUSER=docvault
PGPASSWORD=changeme
PGDATABASE=docvault
PGSSL=false

# Auth
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=8h
SEED_ADMIN_EMAIL=admin@docvault.dev
SEED_ADMIN_PASSWORD=changeme123

# S3
S3_BUCKET=docvault-files-yourname
AWS_REGION=ap-south-1
# No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here - production reads
# temporary credentials from the EC2 instance's attached IAM role.
# For local dev only, export these in your shell from a personal IAM
# user scoped to this one bucket. Never commit them.

# AI summaries
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
