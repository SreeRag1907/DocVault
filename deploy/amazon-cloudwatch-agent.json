{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/nginx/access.log",
            "log_group_name": "docvault-nginx-access",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/nginx/error.log",
            "log_group_name": "docvault-nginx-error",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/home/ubuntu/.pm2/logs/docvault-api-out.log",
            "log_group_name": "docvault-pm2-stdout",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/home/ubuntu/.pm2/logs/docvault-api-error.log",
            "log_group_name": "docvault-pm2-stderr",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          }
        ]
      }
    }
  }
}
